{
  "name": "video-editor",
  "version": "1.0.0",
  "description": "Editor de video",
  "main": "main.js",
  "scripts": {
    "start": "electron --ozone-platform=x11 .",
    "build:linux":   "electron-builder --linux",
    "build:windows": "electron-builder --win",
    "build:mac":     "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "build": {
    "appId": "com.kayru.videoeditor",
    "productName": "VideoEdit",
    "extraFiles": [
      {
        "from": "bin/${os}",
        "to": "resources/bin",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Video"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    }
  }
}