{
  "name": "video-editor",
  "version": "1.0.0",
  "description": "Editor de video",
  "main": "main.js",
  "scripts": {
    "start": "electron --ozone-platform=x11 .",
    "build:linux":   "electron-builder --linux",
    "build:windows": "electron-builder --win",
    "build:mac":     "electron-builder --mac",
    "release:win":   "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^24.0.0"
  },
  "dependencies": {
    "fluent-ffmpeg": "^2.1.3"
  },
  "build": {
    "appId": "com.kayru.videoeditor",
    "productName": "VideoEdit",
    "publish": {
      "provider": "github",
      "owner": "K-A-Y-R-U",
      "repo": "video-editor"
    },
    "extraFiles": [
      {
        "from": "bin/win",
        "to": "resources/bin",
        "filter": ["*.exe"],
        "platform": ["win"]
      },
      {
        "from": "bin/linux",
        "to": "resources/bin",
        "filter": ["ffmpeg", "ffprobe"],
        "platform": ["linux"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Video"
    },
    "win": {
      "target": ["nsis"],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "assets/icon.icns"
    }
  }
}