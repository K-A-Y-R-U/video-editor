/**
 * setup-ffmpeg.js
 * Descarga ffmpeg y ffprobe para la plataforma actual.
 * Uso: node setup-ffmpeg.js
 *
 * - Windows → descarga ffmpeg-master-latest-win64-gpl.zip desde GitHub
 * - Linux   → avisa que use el gestor de paquetes
 * - Mac     → avisa que use brew
 *
 * Los binarios se guardan en bin/<plataforma>/ y NO se suben al repo (.gitignore).
 */

const https    = require('https')
const fs       = require('fs')
const path     = require('path')
const { execSync } = require('child_process')

const PLATFORM = process.platform  // win32 | linux | darwin

// ── Utilidades ────────────────────────────────────────────────────────────────

function log(msg)  { console.log('  [setup] ' + msg) }
function ok(msg)   { console.log('  ✓ ' + msg) }
function err(msg)  { console.error('  ✗ ' + msg); process.exit(1) }

function download(url, dest) {
  return new Promise((resolve, reject) => {
    log('Descargando: ' + url)
    const file = fs.createWriteStream(dest)
    function get(u) {
      https.get(u, res => {
        if (res.statusCode === 301 || res.statusCode === 302) {
          return get(res.headers.location)
        }
        if (res.statusCode !== 200) {
          return reject(new Error('HTTP ' + res.statusCode + ' → ' + u))
        }
        const total = parseInt(res.headers['content-length'] || '0')
        let downloaded = 0
        res.on('data', chunk => {
          downloaded += chunk.length
          if (total > 0) {
            const pct = Math.round(downloaded / total * 100)
            process.stdout.write(`\r  Progreso: ${pct}% (${(downloaded/1024/1024).toFixed(1)} MB)   `)
          }
        })
        res.pipe(file)
        res.on('end', () => { process.stdout.write('\n'); resolve() })
      }).on('error', reject)
    }
    get(url)
    file.on('error', reject)
  })
}

// ── Windows ───────────────────────────────────────────────────────────────────

async function setupWindows() {
  const binDir = path.join(__dirname, 'bin', 'win')
  const ffmpegDest  = path.join(__dirname, 'bin', 'win', 'ffmpeg.exe')
  const ffprobeDest = path.join(__dirname, 'bin', 'win', 'ffprobe.exe')

  if (fs.existsSync(ffmpegDest) && fs.existsSync(ffprobeDest)) {
    ok('ffmpeg y ffprobe ya están en bin/win/ — nada que hacer.')
    return
  }

  fs.mkdirSync(binDir, { recursive: true })

  // Descargar zip de BtbN (build oficial de ffmpeg para Windows)
  const ZIP_URL = 'https://github.com/BtbN/FFmpeg-Builds/releases/download/latest/ffmpeg-master-latest-win64-gpl.zip'
  const zipPath = path.join(__dirname, 'ffmpeg-win.zip')

  log('Esto puede tardar unos minutos (~200MB)...')
  await download(ZIP_URL, zipPath)

  // Descomprimir con PowerShell (viene en Windows 10+)
  log('Descomprimiendo...')
  const extractDir = path.join(__dirname, '_ffmpeg_tmp')
  fs.mkdirSync(extractDir, { recursive: true })

  execSync(
    `powershell -Command "Expand-Archive -Force '${zipPath}' '${extractDir}'"`,
    { stdio: 'inherit' }
  )

  // Buscar ffmpeg.exe y ffprobe.exe dentro del zip extraído
  function findExe(dir, name) {
    for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
      const full = path.join(dir, entry.name)
      if (entry.isDirectory()) {
        const found = findExe(full, name)
        if (found) return found
      } else if (entry.name.toLowerCase() === name) {
        return full
      }
    }
    return null
  }

  const foundFfmpeg  = findExe(extractDir, 'ffmpeg.exe')
  const foundFfprobe = findExe(extractDir, 'ffprobe.exe')

  if (!foundFfmpeg || !foundFfprobe) {
    err('No se encontraron los binarios dentro del zip. Descarga manualmente desde https://ffmpeg.org/download.html')
  }

  fs.copyFileSync(foundFfmpeg,  ffmpegDest)
  fs.copyFileSync(foundFfprobe, ffprobeDest)

  // Limpieza
  fs.rmSync(zipPath,    { force: true })
  fs.rmSync(extractDir, { recursive: true, force: true })

  ok(`ffmpeg  → bin/win/ffmpeg.exe`)
  ok(`ffprobe → bin/win/ffprobe.exe`)
  ok('¡Listo! Ahora puedes correr: npm start')
}

// ── Linux / Mac ───────────────────────────────────────────────────────────────

function setupLinux() {
  log('En Linux ffmpeg se instala con el gestor de paquetes:')
  console.log()
  console.log('    Fedora/RHEL:   sudo dnf install ffmpeg')
  console.log('    Ubuntu/Debian: sudo apt install ffmpeg')
  console.log('    Arch:          sudo pacman -S ffmpeg')
  console.log()
  ok('Si ya lo tienes instalado, npm start debería funcionar sin problemas.')
}

function setupMac() {
  log('En macOS ffmpeg se instala con Homebrew:')
  console.log()
  console.log('    brew install ffmpeg')
  console.log()
  ok('Si ya lo tienes instalado, npm start debería funcionar sin problemas.')
}

// ── Main ──────────────────────────────────────────────────────────────────────

;(async () => {
  console.log()
  console.log('══════════════════════════════════════')
  console.log('  VideoEdit — Setup de FFmpeg')
  console.log('══════════════════════════════════════')
  console.log()

  try {
    if (PLATFORM === 'win32')       await setupWindows()
    else if (PLATFORM === 'linux')  setupLinux()
    else if (PLATFORM === 'darwin') setupMac()
    else { log('Plataforma no reconocida: ' + PLATFORM); process.exit(1) }
  } catch(e) {
    err(e.message || String(e))
  }

  console.log()
})()